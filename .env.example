# Corify environment
# Copy to .env and fill live values. Never commit .env.

# Backend
PORT=8787
NODE_ENV=development

# Mainnet data reads
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=replace-me
BIRDEYE_API_KEY=replace-me

# Optional LLM brief
# Corify does not need the solana_coralOS TxLINE/Venice starter variables.
# Set these only if you want the backend to add a consumer-facing research brief.
LLM_PROVIDER=gemini
LLM_MODEL=gemini-3.5-flash
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_API_KEY=replace-me
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
VENICE_API_KEY=

# Devnet settlement
SOLANA_RPC_URL=https://api.devnet.solana.com
DEVNET_KEYPAIR_PATH=/home/you/.config/solana/id.json
LEDGER_KEYPAIR_PATH=/home/you/.config/solana/ledger.json
SELLER_KEYPAIR_PATH=/home/you/.config/solana/seller.json
SELLER_PUBLIC_KEY=replace-with-devnet-seller-pubkey
CORAL_SESSION_KEYPAIR_PATH=/home/you/.config/solana/coral-session.json
CORIFY_ESCROW_PROGRAM_ID=R5NWNg9eRLWWQU81Xbzz5Du1k7jTDeeT92Ty6qCeXet

# Coral runtime
CORAL_BASE_URL=http://localhost:5555
CORAL_AUTH_KEY=replace-me
CORAL_CONNECTION_URL=stdio://corify-local

# Local deterministic smoke mode
# Use fixture/offline only for tests and local smoke runs.
CORIFY_DATA_MODE=live
CORIFY_SETTLEMENT_MODE=live
DEMO_WALLET_ADDRESS=Vote111111111111111111111111111111111111111
DEMO_TOKEN_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
