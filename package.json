{
  "name": "corify",
  "version": "0.1.0",
  "description": "Solana CoralOS agent market for verified wallet and token intelligence",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "agents/",
    "backend/",
    "contracts/",
    "engine/",
    "frontend/",
    "lib/",
    "scripts/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "pnpm run build:ts",
    "build:ts": "tsc -p tsconfig.build.json",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "demo": "bash scripts/demo.sh",
    "backend": "pnpm run build:ts && node dist/backend/server.js",
    "start": "node dist/backend/server.js",
    "setup:check": "pnpm run build:ts && node dist/scripts/setup.js check",
    "setup:keys": "pnpm run build:ts && node dist/scripts/setup.js keys",
    "setup:airdrop": "pnpm run build:ts && node dist/scripts/airdrop.js",
    "coral:check": "pnpm run build:ts && node dist/scripts/coral-check.js",
    "data:smoke": "pnpm run build:ts && node dist/scripts/live-data-smoke.js",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier . -w",
    "format:check": "prettier . -c",
    "check": "pnpm run format:check && pnpm run typecheck && pnpm run lint && pnpm test",
    "dev": "pnpm run backend",
    "clean": "rm -rf dist node_modules/.cache/tsbuildinfo"
  },
  "keywords": [
    "solana",
    "coralos",
    "agents",
    "escrow",
    "micropayments"
  ],
  "author": "",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": ""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@solana/web3.js": "^1.98.4",
    "bs58": "^6.0.0",
    "express": "^5.2.1",
    "openai": "^6.45.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/express": "^5.0.6",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.50.0",
    "@typescript-eslint/parser": "^8.50.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.39.2",
    "eslint-plugin-sonarjs": "^3.0.5",
    "eslint-plugin-unicorn": "^62.0.0",
    "eslint-plugin-unused-imports": "^4.3.0",
    "globals": "^16.5.0",
    "prettier": "^3.7.4",
    "supertest": "^7.1.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "lint-staged": {
    "*.{ts,tsx,js}": [
      "eslint --fix",
      "prettier -w"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier -w"
    ]
  }
}
